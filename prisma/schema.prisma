generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuctionSession {
  id           String        @id @default(cuid())
  name         String
  isActive     Boolean       @default(true)
  totalPoints  Int           @default(1000)
  unsoldIterationRound Int   @default(1)
  unsoldIterationAnchorPlayerId String?
  restartAckRequired Boolean @default(false)
  isAuctionEnded Boolean     @default(false)
  auctionEndReason AuctionEndReason?
  endedAt      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  teams        Team[]
  players      Player[]
  transactions Transaction[]
  actionHistory AuctionActionHistory[]
  imageIngestionRuns ImportImageIngestionRun[]
  imageIngestionJobs ImportImageIngestionJob[]
}

model Team {
  id               String         @id @default(cuid())
  name             String
  shortCode        String         @unique
  domain           String
  pointsTotal      Int            @default(1000)
  pointsSpent      Int            @default(0)
  sessionId        String
  session          AuctionSession @relation(fields: [sessionId], references: [id])
  players          Player[]
  roleProfiles     TeamRoleProfile[]
  transactions     Transaction[]
  createdAt        DateTime       @default(now())

  @@index([sessionId])
}

model Player {
  id              String         @id @default(cuid())
  name            String
  position1       String
  position2       String?
  year            String?
  imageUrl        String?
  basePrice       Int            @default(10)
  status          PlayerStatus   @default(UNSOLD)
  teamId          String?
  team            Team?          @relation(fields: [teamId], references: [id])
  sessionId       String
  session         AuctionSession @relation(fields: [sessionId], references: [id])
  transactions    Transaction[]
  actionHistoryFrom AuctionActionHistory[] @relation("AuctionActionFromPlayer")
  actionHistoryTo AuctionActionHistory[] @relation("AuctionActionToPlayer")
  imageIngestionJobs ImportImageIngestionJob[]
  whatsappNumber  String?
  stream          String         @default("")
  importOrder     Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([sessionId, importOrder])
}

enum PlayerStatus {
  UNSOLD
  SOLD
  IN_AUCTION
}

enum TeamRole {
  OWNER
  CO_OWNER
  CAPTAIN
  MARQUEE
}

enum ImportImageRunStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
}

enum ImportImageJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AuctionActionType {
  PASS
  SELL
}

enum AuctionEndReason {
  UNSOLD_DEPLETED
  ITERATION_LIMIT_REACHED
}

model AuctionActionHistory {
  id            String            @id @default(cuid())
  sessionId     String
  session       AuctionSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fromPlayerId  String
  fromPlayer    Player            @relation("AuctionActionFromPlayer", fields: [fromPlayerId], references: [id], onDelete: Cascade)
  toPlayerId    String?
  toPlayer      Player?           @relation("AuctionActionToPlayer", fields: [toPlayerId], references: [id], onDelete: SetNull)
  actionType    AuctionActionType
  transactionId String?           @unique
  transaction   Transaction?      @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())

  @@index([sessionId, createdAt])
  @@index([actionType])
  @@index([fromPlayerId, createdAt])
  @@index([toPlayerId, createdAt])
}

model ImportImageIngestionRun {
  id            String               @id @default(cuid())
  sessionId     String
  session       AuctionSession       @relation(fields: [sessionId], references: [id])
  status        ImportImageRunStatus @default(PENDING)
  totalJobs     Int                  @default(0)
  completedJobs Int                  @default(0)
  failedJobs    Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  startedAt     DateTime?
  finishedAt    DateTime?
  jobs          ImportImageIngestionJob[]

  @@index([sessionId, createdAt])
  @@index([status, createdAt])
}

model ImportImageIngestionJob {
  id           String               @id @default(cuid())
  runId        String
  run          ImportImageIngestionRun @relation(fields: [runId], references: [id])
  sessionId    String
  session      AuctionSession       @relation(fields: [sessionId], references: [id])
  playerId     String
  player       Player               @relation(fields: [playerId], references: [id])
  sourceUrl    String
  sourceFileId String
  sourceHash   String
  storagePath  String?
  status       ImportImageJobStatus @default(PENDING)
  attemptCount Int                  @default(0)
  maxAttempts  Int                  @default(3)
  nextAttemptAt DateTime?
  lastError    String?
  contentType  String?
  contentLength Int?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  startedAt    DateTime?
  finishedAt   DateTime?

  @@unique([runId, playerId, sourceHash])
  @@index([runId, status, nextAttemptAt])
  @@index([sessionId, status, nextAttemptAt])
  @@index([playerId])
}

model TeamRoleProfile {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  role      TeamRole
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, role])
  @@index([teamId])
}

model Transaction {
  id        String         @id @default(cuid())
  playerId  String
  player    Player         @relation(fields: [playerId], references: [id])
  teamId    String
  team      Team           @relation(fields: [teamId], references: [id])
  sessionId String
  session   AuctionSession @relation(fields: [sessionId], references: [id])
  actionHistory AuctionActionHistory?
  amount    Int
  createdAt DateTime       @default(now())

  @@index([sessionId])
}
